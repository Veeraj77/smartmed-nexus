NODE_ENV=development
PORT=5000

# MongoDB
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/smartmed-nexus?retryWrites=true&w=majority

# JWT
JWT_SECRET=your_jwt_secret_key_min_32_chars_long_change_in_production
JWT_EXPIRES_IN=7d

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Socket.io
SOCKET_CORS_ORIGIN=http://localhost:5173

# Frontend URL
FRONTEND_URL=http://localhost:5173

# AI Service (optional - for OpenAI integration)
OPENAI_API_KEY=
